# Environment Variables for XSavLab

# Firebase Cloud Functions
# The enquiry endpoint will be set automatically for production
# For local development, the function will use the local emulator
REACT_APP_ENQUIRY_ENDPOINT=https://us-central1-xsavlab.cloudfunctions.net/sendEnquiry

# Note: Email configuration is handled in Cloud Functions
# Set these environment variables when deploying Firebase Cloud Functions:
# - EMAIL_USER: Gmail address or email service account
# - EMAIL_PASSWORD: Gmail app password or service account token
# - ADMIN_EMAIL: Email address for admin notifications
