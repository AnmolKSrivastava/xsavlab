rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.admin == true;
    }
    
    // Helper function to check if user is super admin
    function isSuperAdmin() {
      return isAuthenticated() && 
             request.auth.token.role == 'superadmin';
    }
    
    // Helper function to check if user has minimum role
    function hasRole(minRole) {
      let userRole = request.auth.token.role;
      return isAuthenticated() && 
             (userRole == 'superadmin' || 
              (minRole == 'admin' && (userRole == 'admin' || userRole == 'superadmin')) ||
              (minRole == 'moderator' && (userRole == 'moderator' || userRole == 'admin' || userRole == 'superadmin')));
    }
    
    // Enquiries collection - locked down
    match /enquiries/{enquiryId} {
      // Only authenticated admins can read enquiries
      allow read: if isAdmin();
      
      // Only admins can update status and isRead fields
      allow update: if isAdmin() && 
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'isRead', 'updatedAt', 'readAt']);
      
      // Only Cloud Functions can create enquiries
      // Cloud Functions use Admin SDK which bypasses security rules
      allow create, delete: if false;
    }
    
    // Admins collection - manage admin users
    match /admins/{userId} {
      // Only admins can read admin list
      allow read: if isAdmin();
      
      // Only admins can create/update other admins
      allow write: if isAdmin();
    }
    
    // Users collection - role-based user management
    match /users/{userId} {
      // Super admins can read all users, regular admins can read users too
      allow read: if hasRole('admin');
      
      // Only super admins can create users (via Cloud Function)
      // Users can update their own profile (limited fields)
      allow update: if isSuperAdmin() || 
                     (request.auth.uid == userId && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['displayName', 'updatedAt']));
      
      // Only Cloud Functions can create/delete
      allow create, delete: if false;
    }
    
    // Ventures collection - showcase your products
    match /ventures/{ventureId} {
      // Everyone can read published ventures
      allow read: if resource.data.status == 'live' || isAdmin();
      
      // Only admins and super admins can create/update ventures
      allow create, update: if hasRole('admin');
      
      // Only super admins can delete ventures
      allow delete: if isSuperAdmin();
    }
    
    // Site Settings collection - editable statistics and content
    match /siteSettings/{settingId} {
      // Everyone can read site settings (for displaying stats)
      allow read: if true;
      
      // Only admins can update site settings
      allow update: if hasRole('admin');
      
      // Creation and deletion handled via Cloud Functions only
      allow create, delete: if false;
    }
    
    // Success Stories / Case Studies collection
    match /successStories/{storyId} {
      // Everyone can read published stories
      allow read: if resource.data.status == 'live' || isAdmin();
      
      // Only admins can create/update stories
      allow create, update: if hasRole('admin');
      
      // Only super admins can delete stories
      allow delete: if isSuperAdmin();
    }
    
    // Client Reviews collection
    match /reviews/{reviewId} {
      // Everyone can read approved reviews
      allow read: if resource.data.status == 'approved' || isAdmin();
      
      // Anyone can create a review (client submission)
      allow create: if request.auth != null;
      
      // Only admins can update reviews (moderation/editing)
      allow update: if hasRole('admin');
      
      // Only super admins can delete reviews
      allow delete: if isSuperAdmin();
    }

    // Blog Posts Collection
    match /blogPosts/{postId} {
      // Public can read published posts
      allow read: if resource.data.status == 'published' || isAdmin();
      
      // Authenticated users can create posts (as drafts)
      allow create: if isAuthenticated() 
        && request.resource.data.status == 'draft'
        && request.resource.data.author.uid == request.auth.uid;
      
      // Authors can update their own drafts, admins can update any post
      allow update: if (isAdmin() || 
        (resource.data.author.uid == request.auth.uid && resource.data.status == 'draft'));
      
      // Only admins can delete posts
      allow delete: if isAdmin();
    }

    // Jobs Collection
    match /jobs/{jobId} {
      // Public can read open jobs
      allow read: if resource.data.status == 'open' || isAdmin();
      
      // Only admins can create jobs
      allow create: if isAdmin();
      
      // Only admins can update jobs
      allow update: if isAdmin();
      
      // Only admins can delete jobs
      allow delete: if isAdmin();
    }

    // Applications Collection
    match /applications/{applicationId} {
      // Public cannot read applications
      // Only admins can read all applications
      allow read: if isAdmin();
      
      // Anyone can create an application (submit)
      allow create: if request.auth != null;
      
      // Only admins can update applications (change status, add notes)
      allow update: if isAdmin();
      
      // Only admins can delete applications
      allow delete: if isAdmin();
    }
    
    // By default, deny all access to any other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
